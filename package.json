{
  "name": "ladybird-best",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "vite build && node scripts/postbuild.mjs",
    "preview": "vite preview --host 127.0.0.1",
    "test": "node --test test/*.test.mjs && npm run build",
    "cloudflare:deploy": "npm run build && npx wrangler deploy --keep-vars",
    "pages:deploy": "npm run build && npx wrangler pages deploy dist --project-name my-ladybird --branch main"
  },
  "dependencies": {
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "playwright": "^1.59.1",
    "vite": "^8.0.1",
    "wrangler": "^4.45.0"
  }
}
